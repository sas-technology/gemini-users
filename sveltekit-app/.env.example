# Password to log in to the dashboard
DASHBOARD_SECRET=choose-a-strong-password

# From Apps Script setup — Deploy → Manage Deployments → Web App URL
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# From Apps Script setup — Project Settings → Script Properties → API_KEY
APPS_SCRIPT_API_KEY=your-api-key

# Required by SvelteKit adapter-node for CSRF and cookie handling
ORIGIN=http://localhost:3000
