# Dashboard access password — set this to a strong, secret value
DASHBOARD_SECRET=change-me-to-a-strong-password

# Deployed Google Apps Script web app URL
# In Apps Script editor: Deploy → Manage Deployments → copy the web app URL
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# API key to protect the JSON endpoints
# Set this in Apps Script editor: Project Settings → Script Properties → API_KEY = <same value>
APPS_SCRIPT_API_KEY=change-me-to-a-strong-api-key
