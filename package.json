{
  "name": "gemini-users",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "markdownlint": "markdownlint '**/*.md' --ignore node_modules --ignore sveltekit-app/node_modules"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,css,json,html,md,yaml,yml}": "prettier --write --ignore-unknown"
  }
}
